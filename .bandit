[bandit]
# Bandit configuration file for gcc-evo

# Files to exclude
exclude_dirs =
    /tests/
    /.tox/
    /.venv/
    /venv/
    /build/
    /dist/
    /.eggs/

# Tests to run
tests =
    B101,  # assert_used
    B102,  # exec_used
    B103,  # set_bad_file_permissions
    B104,  # hardcoded_bind_all_interfaces
    B105,  # hardcoded_password_string
    B106,  # hardcoded_password_funcarg
    B107,  # hardcoded_password_default
    B108,  # hardcoded_tmp_directory
    B110,  # try_except_pass
    B112,  # try_except_handler_order
    B201,  # flask_debug_true
    B301,  # pickle
    B302,  # marshal
    B303,  # md5
    B304,  # des
    B305,  # cipher
    B306,  # mktemp_q
    B307,  # eval
    B308,  # mark_safe
    B309,  # httpsconnection
    B310,  # urllib_urlopen
    B311,  # random
    B312,  # telnetlib
    B313,  # unverified_context
    B314,  # unverified_ssl_context
    B315,  # xml_bad_etree
    B316,  # xml_bad_elemtree
    B317,  # xml_bad_expat_reader
    B318,  # xml_bad_expat_sax
    B319,  # xml_bad_pulldom
    B320,  # xml_bad_sax
    B321,  # ftplib
    B322,  # unverified_ftp_context
    B323,  # unverified_telnetlib
    B324,  # hashlib
    B325,  # tempnam
    B401,  # import_telnetlib
    B402,  # import_ftplib
    B403,  # import_pickle
    B404,  # import_subprocess
    B405,  # import_xml_etree
    B406,  # import_xml_sax
    B407,  # import_xml_pulldom
    B408,  # import_xml_expat
    B409,  # import_xmlrpc
    B410,  # import_httpoxy
    B411,  # import_xmlrpclib
    B501,  # request_verify
    B502,  # request_with_no_cert_validation
    B503,  # ssl_with_bad_version
    B504,  # ssl_with_bad_defaults
    B505,  # weak_cryptographic_key
    B506,  # yaml_load
    B507,  # ssh_no_host_key_verification
    B601,  # paramiko_calls
    B602,  # popen_with_shell_equals_true
    B603,  # subprocess_without_shell_equals_true
    B604,  # any_other_function_with_shell_equals_true
    B605,  # start_process_with_a_shell
    B606,  # start_process_with_partial_path
    B607,  # partial_paramiko_call
    B608,  # hardcoded_sql_string
    B609,  # wildcard_injection
    B610,  # django_sql_injection
    B611,  # django_injection
    B701,  # jinja2_autoescape_false
    B702,  # mako_templates
    B703,  # django_mark_safe

# Severity level (LOW, MEDIUM, HIGH)
level = MEDIUM

# Confidence level (LOW, MEDIUM, HIGH)
confidence = MEDIUM

# Skip tests
skips =
    B101,  # assert_used - allow in tests
    B601,  # paramiko_calls - allow paramiko usage

[bandit:assert_used]
skips = */tests/*

[bandit:hardcoded_password_string]
# Exclude common test patterns
skips =
    tests/*/test_*
    *_test.py
