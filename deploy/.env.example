# ============================================================================
# AI PRO TRADING SYSTEM v3.572 - 环境变量配置模板
# ============================================================================
# 使用方法:
# 1. 复制此文件为 .env
# 2. 填入实际的密钥和配置
# 3. Windows: 运行 setup.bat 自动设置环境变量
# 4. Linux/Mac: source .env 或在 ~/.bashrc 中添加 export
# ============================================================================

# ----------------------------------------------------------------------------
# 必需 - AI API密钥
# ----------------------------------------------------------------------------
OPENAI_API_KEY=sk-your-openai-api-key-here
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here

# ----------------------------------------------------------------------------
# 必需 - 3Commas交易执行 (加密货币)
# ----------------------------------------------------------------------------
# 从3commas.io获取webhook URL和密钥
THREECOMMAS_WEBHOOK_URL=https://3commas.io/trade_signal/xxxxxxxx
THREECOMMAS_SECRET=your-3commas-secret-here

# ----------------------------------------------------------------------------
# 必需 - SignalStack交易执行 (美股)
# ----------------------------------------------------------------------------
# 从signalstack.com获取webhook URL和密钥
SIGNALSTACK_WEBHOOK_URL=https://app.signalstack.com/webhook/xxxxxxxx
SIGNALSTACK_SECRET=your-signalstack-secret-here

# ----------------------------------------------------------------------------
# 可选 - 服务器配置
# ----------------------------------------------------------------------------
PORT=6001
MAIN_TIMEFRAME=30
L2_10M_STATE_FILE=logs/l2_10m_state.json

# ----------------------------------------------------------------------------
# 可选 - Coinbase API (如果使用Coinbase获取数据)
# ----------------------------------------------------------------------------
# COINBASE_API_KEY_NAME=organizations/xxx/apiKeys/xxx
# COINBASE_PRIVATE_KEY=-----BEGIN EC PRIVATE KEY-----\nxxx\n-----END EC PRIVATE KEY-----

# ----------------------------------------------------------------------------
# 可选 - 邮件通知 (默认已在代码中配置)
# ----------------------------------------------------------------------------
# EMAIL_SMTP_SERVER=smtp.gmail.com
# EMAIL_SMTP_PORT=587
# EMAIL_FROM=your-email@gmail.com
# EMAIL_PASSWORD=your-app-password
# EMAIL_TO=recipient@example.com
